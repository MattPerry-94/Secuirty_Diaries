<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TabPane prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.security_diaries.DiariesController">

    <tabs>
        <Tab onSelectionChanged="#ReloadEvent" text="Journal">
            <content>
                <BorderPane prefHeight="371.0" prefWidth="600.0">
                    <top>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <children>
                                <Button mnemonicParsing="false" onAction="#logout" text="Déconnexion" />
                            </children>
                        </HBox>
                    </top>
                    <center>
                        <TableView fx:id="diary">
                            <columns>
                                <TableColumn fx:id="type" prefWidth="176.79998779296875" text="Type" />
                                <TableColumn fx:id="title" prefWidth="162.4000244140625" text="Titre" />
                                <TableColumn fx:id="begin" prefWidth="140.0" text="Date début" />
                                <TableColumn fx:id="end" prefWidth="118.39996337890625" text="Date fin" />
                            </columns>
                        </TableView>
                    </center>
                </BorderPane>
            </content>
        </Tab>
        <Tab text="Ajouter un événement">
            <content>
                <BorderPane prefHeight="371.0" prefWidth="600.0">
                    <top>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <children>
                                <Button mnemonicParsing="false" onAction="#logout" text="Déconnexion" />
                            </children>
                        </HBox>
                    </top>
                    <center>
                        <VBox prefHeight="371.0" prefWidth="600.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="17.0" prefWidth="600.0" text="Nom de l'événement">
                           <VBox.margin>
                              <Insets bottom="10.0" top="10.0" />
                           </VBox.margin>
                           <font>
                              <Font name="Cambria" size="18.0" />
                           </font>
                        </Label>
                        <TextField fx:id="NameEvent" alignment="TOP_CENTER" prefHeight="26.0" prefWidth="600.0">
                           <VBox.margin>
                              <Insets bottom="10.0" top="5.0" />
                           </VBox.margin>
                        </TextField>
                        <Label alignment="CENTER" prefHeight="18.0" prefWidth="597.0" text="Typologie de l'événement">
                           <VBox.margin>
                              <Insets bottom="10.0" top="10.0" />
                           </VBox.margin>
                           <font>
                              <Font name="Cambria" size="18.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="TypeEvent" prefHeight="28.0" prefWidth="598.0">
                           <VBox.margin>
                              <Insets bottom="10.0" top="5.0" />
                           </VBox.margin></ComboBox>
                        <Label alignment="CENTER" prefHeight="22.0" prefWidth="624.0" text="Description">
                           <VBox.margin>
                              <Insets bottom="10.0" top="10.0" />
                           </VBox.margin>
                           <font>
                              <Font name="Cambria" size="18.0" />
                           </font>
                        </Label>
                        <TextArea fx:id="ContentEvent" prefHeight="129.0" prefWidth="580.0">
                           <VBox.margin>
                              <Insets bottom="10.0" top="10.0" />
                           </VBox.margin>
                        </TextArea>
                        <HBox prefHeight="100.0" prefWidth="200.0">
                           <children>
                              <VBox prefHeight="66.0" prefWidth="198.0">
                                 <children>
                                    <Label prefHeight="17.0" prefWidth="161.0" text="Date de début">
                                       <font>
                                          <Font name="Cambria" size="13.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets left="10.0" />
                                       </VBox.margin>
                                    </Label>
                                    <DatePicker fx:id="BeginDate" prefWidth="170.0">
                                       <VBox.margin>
                                          <Insets left="5.0" right="10.0" top="10.0" />
                                       </VBox.margin>
                                    </DatePicker>
                                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                                       <children>
                                          <Spinner fx:id="BeginHour" editable="true" prefWidth="75.0" />
                                          <Label text=":" />
                                          <Spinner fx:id="BeginMinute" editable="true" prefWidth="75.0" />
                                       </children>
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
                                       </VBox.margin>
                                    </HBox>
                                 </children>
                              </VBox>
                              <VBox prefHeight="60.0" prefWidth="194.0">
                                 <children>
                                    <Label prefHeight="17.0" prefWidth="161.0" text="Date de fin">
                                       <font>
                                          <Font name="Cambria" size="13.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets left="10.0" />
                                       </VBox.margin>
                                    </Label>
                                    <DatePicker fx:id="EndDate" prefWidth="170.0">
                                       <VBox.margin>
                                          <Insets left="5.0" top="10.0" />
                                       </VBox.margin>
                                    </DatePicker>
                                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                                       <children>
                                          <Spinner fx:id="EndHour" editable="true" prefWidth="75.0" />
                                          <Label text=":" />
                                          <Spinner fx:id="EndMinute" editable="true" prefWidth="75.0" />
                                       </children>
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="5.0" top="5.0" />
                                       </VBox.margin>
                                    </HBox>
                                 </children>
                              </VBox>
                              <VBox prefHeight="60.0" prefWidth="209.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#AddEvent" prefHeight="40.0" prefWidth="115.0" text="Ajouter">
                                       <font>
                                          <Font name="Cambria Italic" size="14.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets left="75.0" top="10.0" />
                                       </VBox.margin>
                                    </Button>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                    </center>
                </BorderPane>
            </content>
        </Tab>
    </tabs>
</TabPane>
